{
  "name": "@tonysimons/openclaw-doctor",
  "version": "0.1.3",
  "description": "Diagnostic CLI for OpenClaw workspaces — detect config drift, memory hygiene issues, cron failures, and missing operational guardrails before they cost you hours.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "cli",
    "diagnostics",
    "doctor",
    "operations",
    "workspace",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "openclaw-doctor": "./dist/bin/doctor.js",
    "doctor": "./dist/bin/doctor.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/bin/doctor.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "verify": "npm run typecheck && npm test && npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10"
}
